{
  "expo": {
    "name": "Yoink It",
    "slug": "yoink-it",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/images/icon.png",
    "scheme": "yoinkit",
    "userInterfaceStyle": "light",
    "newArchEnabled": true,
    "splash": {
      "image": "./assets/images/splash-icon.png",
      "resizeMode": "contain",
      "backgroundColor": "#FBF6EE"
    },
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "com.asbaker.yoinkit"
    },
    "android": {
      "package": "com.asbaker.yoinkit",
      "adaptiveIcon": {
        "foregroundImage": "./assets/images/adaptive-icon.png",
        "backgroundColor": "#ffffff"
      },
      "edgeToEdgeEnabled": true,
      "predictiveBackGestureEnabled": false
    },
    "web": {
      "bundler": "metro",
      "output": "static",
      "favicon": "./assets/images/favicon.png"
    },
    "plugins": [
      "expo-router"
    ],
    "experiments": {
      "typedRoutes": true
    },
    "extra": {
      "router": {},
      "eas": {
        "projectId": "56ed4e2d-41c3-431d-9520-edb1af661e0f"
      }
    },
    "owner": "asbaker"
  }
}
